# Copy to .env for local overrides.
# Default uses SQLite so the backend runs without Docker.
DATABASE_URL=sqlite:///./tours.db

# For Postgres via docker-compose:
# DATABASE_URL=postgresql+psycopg://tours:tours@localhost:5432/tours

# Absolute path overrides the bundled seed file resolution.
# SEED_PATH=/absolute/path/to/contracts/tours_seed.json

# Comma-separated browser origins appended to local defaults (Railway static site + separate API).
# CORS_ORIGINS=https://your-frontend.up.railway.app
